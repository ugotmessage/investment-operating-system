{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://investment-operating-system.local/schemas/prediction-card.schema.json",
  "title": "Prediction Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "prediction_id",
    "created_at",
    "entity_id",
    "type",
    "statement",
    "confidence",
    "time_horizon",
    "evidence_ids",
    "success_criteria",
    "failure_criteria",
    "checkpoints",
    "immutable"
  ],
  "properties": {
    "prediction_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "entity_id": {"type": "string"},
    "event_id": {"type": ["string", "null"]},
    "playbook_version": {"type": "string"},
    "research_run_id": {"type": "string"},
    "type": {
      "enum": [
        "event",
        "fundamental",
        "causal_fundamental",
        "financial_estimate",
        "consensus_revision",
        "market_reaction",
        "supply_chain"
      ]
    },
    "statement": {"type": "string", "minLength": 20},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "time_horizon": {"type": "string"},
    "evidence_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "counter_evidence_ids": {"type": "array", "items": {"type": "string"}},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "success_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "failure_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "checkpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["checkpoint_id", "kind", "due_at", "metrics"],
        "properties": {
          "checkpoint_id": {"type": "string"},
          "kind": {"enum": ["event", "operational", "financial", "market", "manual"]},
          "due_at": {"type": "string", "format": "date-time"},
          "metrics": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "source_requirements": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "immutable": {"const": true},
    "content_hash": {"type": "string"}
  }
}
